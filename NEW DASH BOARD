            <div class="modal-buttons">
                <button class="modal-save" onclick="saveInstrumentEdit()">Save</button>
                <button class="modal-cancel" onclick="closeEditModal()">Cancel</button>
            </div>
        </div>
    </div>

    <script>
        // Trading pairs with exact investing.com prices
        const pairs = [
            { 
                symbol: 'XAUUSD', 
