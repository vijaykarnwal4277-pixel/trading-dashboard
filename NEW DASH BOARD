                basePrice: 92.09,
                manualRSI: null,
                prevDayLow: 91.00,
                prevDayHigh: 93.50,
                prevDayClose: 92.09,
                nameHi: 'क्रूड ऑयल', 
                nameGu: 'ક્રૂડ ઓઇલ', 
                nameBn: 'ক্রুড অয়েল', 
                nameTe: 'ముడి చమురు'
            },
            { 
                symbol: 'EURUSD', 
                name: 'Euro/USD', 
                basePrice: 1.1537,
                manualRSI: null,
                prevDayLow: 1.1500,
                prevDayHigh: 1.1580,
                prevDayClose: 1.1537,
                nameHi: 'यूरो/डॉलर', 
