            },
            { 
                symbol: 'DXY', 
                name: 'Dollar Index', 
                basePrice: 99.47,
                manualRSI: null,
                prevDayLow: 98.80,
                prevDayHigh: 100.20,
                prevDayClose: 99.47,
                nameHi: 'डॉलर इंडेक्स', 
                nameGu: 'ડોલર ઇન્ડેક્સ', 
                nameBn: 'ডলার ইনডেক্স', 
                nameTe: 'డాలర్ ఇండెక్స్'
            }
        ];

        let currentLang = 'en';
        let currentTimeFrame = '15m';
        let currentCandlePeriod = 14;
        let refreshInterval = 1;
        let timer;
        let currentTimeZone = 'local';
        let currentEditIndex = 0;
        
        // Zoom level
        let zoomLevel = 100;

        // Function to populate pivot instrument dropdown
        function populatePivotDropdown() {
            const select = document.getElementById('pivot-instrument-select');
            select.innerHTML = '';
            pairs.forEach((pair, index) => {
                const option = document.createElement('option');
                option.value = index;
                option.textContent = `${pair.symbol} - ${pair.name}`;
                select.appendChild(option);
            });
        }

        // Function to load selected instrument data into pivot editor
        function loadInstrumentToPivotEditor() {
            const index = document.getElementById('pivot-instrument-select').value;
            if (index !== '') {
                const pair = pairs[index];
                document.getElementById('pivot-prev-low').value = pair.prevDayLow;
                document.getElementById('pivot-prev-high').value = pair.prevDayHigh;
                document.getElementById('pivot-prev-close').value = pair.prevDayClose;
                calculatePivotFromInputs();
            }
        }

        // Function to calculate pivot from inputs
        function calculatePivotFromInputs() {
            const low = parseFloat(document.getElementById('pivot-prev-low').value);
            const high = parseFloat(document.getElementById('pivot-prev-high').value);
            const close = parseFloat(document.getElementById('pivot-prev-close').value);
            
            if (!isNaN(low) && !isNaN(high) && !isNaN(close)) {
                const pivot = (high + low + close) / 3;
                document.getElementById('pivot-calculated').value = pivot.toFixed(
                    document.getElementById('pivot-instrument-select').selectedOptions[0]?.text.includes('XAU') || 
                    document.getElementById('pivot-instrument-select').selectedOptions[0]?.text.includes('OIL') ? 2 : 4
                );
            }
        }

        // Function to apply pivot to selected instrument
        function applyPivotToInstrument() {
            const index = document.getElementById('pivot-instrument-select').value;
            if (index === '') {
                alert('Please select an instrument first!');
                return;
            }
            
            const low = parseFloat(document.getElementById('pivot-prev-low').value);
            const high = parseFloat(document.getElementById('pivot-prev-high').value);
            const close = parseFloat(document.getElementById('pivot-prev-close').value);
            
            if (isNaN(low) || isNaN(high) || isNaN(close)) {
                alert('Please enter valid Low, High, and Close values!');
                return;
            }
            
            // Update the pair's previous day values
            const pair = pairs[index];
            pair.prevDayLow = low;
            pair.prevDayHigh = high;
            pair.prevDayClose = close;
            
            // Recalculate and display pivot
            calculatePivotFromInputs();
            
            // Refresh dashboard and prev day table to show updated pivots
            renderPrevDayTable();
            refreshData();
            
            alert(`Pivot point updated for ${pair.symbol}!`);
        }

        // Function to render Previous Day Table with separate columns
        function renderPrevDayTable() {
            const grid = document.getElementById('prevday-grid');
            grid.innerHTML = '';
            
            pairs.forEach(pair => {
                const decimals = pair.symbol.includes('XAU') || pair.symbol.includes('OIL') ? 2 : 
                                (pair.symbol === 'DXY' ? 3 : 4);
                
                const column = document.createElement('div');
                column.className = 'prevday-column';
                column.innerHTML = `
                    <div class="prevday-symbol">${pair.symbol}</div>
                    <div class="prevday-row">
                        <span class="prevday-label">LOW:</span>
                        <span class="prevday-value prevday-low">$${pair.prevDayLow.toFixed(decimals)}</span>
                    </div>
                    <div class="prevday-row">
                        <span class="prevday-label">HIGH:</span>
                        <span class="prevday-value prevday-high">$${pair.prevDayHigh.toFixed(decimals)}</span>
                    </div>
                    <div class="prevday-row">
                        <span class="prevday-label">CLOSE:</span>
                        <span class="prevday-value prevday-close">$${pair.prevDayClose.toFixed(decimals)}</span>
                    </div>
                `;
                grid.appendChild(column);
            });
        }

        // Get current time in selected timezone
        function getTimeInTimezone() {
            const now = new Date();
            let hours, minutes;
            
            switch(currentTimeZone) {
                case 'UTC':
                    hours = now.getUTCHours();
                    minutes = now.getUTCMinutes();
                    break;
                case 'NY':
                    const nyTime = new Date().toLocaleString('en-US', { timeZone: 'America/New_York' });
                    const nyDate = new Date(nyTime);
                    hours = nyDate.getHours();
                    minutes = nyDate.getMinutes();
                    break;
                case 'London':
                    const londonTime = new Date().toLocaleString('en-GB', { timeZone: 'Europe/London' });
                    const londonDate = new Date(londonTime);
                    hours = londonDate.getHours();
                    minutes = londonDate.getMinutes();
                    break;
                case 'Tokyo':
                    const tokyoTime = new Date().toLocaleString('ja-JP', { timeZone: 'Asia/Tokyo' });
                    const tokyoDate = new Date(tokyoTime);
                    hours = tokyoDate.getHours();
                    minutes = tokyoDate.getMinutes();
                    break;
                case 'Sydney':
                    const sydneyTime = new Date().toLocaleString('en-AU', { timeZone: 'Australia/Sydney' });
                    const sydneyDate = new Date(sydneyTime);
                    hours = sydneyDate.getHours();
                    minutes = sydneyDate.getMinutes();
                    break;
                default:
                    hours = now.getHours();
                    minutes = now.getMinutes();
            }
            return { hours, minutes };
        }

        // Get BULLET POINT value (timezone-aware)
        function getBulletPointValue(symbol) {
            const pair = pairs.find(p => p.symbol === symbol);
            if (pair && pair.manualRSI !== null) {
                return pair.manualRSI;
            }
            
            const { hours, minutes } = getTimeInTimezone();
            
            const baseValues = {
                'XAUUSD': 56.8 + Math.sin(hours / 3) * 4.5 + Math.cos(minutes / 10) * 2.0,
                'USOIL': 59.2 + Math.cos(hours / 4) * 5.8 + Math.sin(minutes / 15) * 3.1,
                'EURUSD': 44.5 + Math.sin((hours + 2) / 3) * 4.2 + Math.cos(minutes / 12) * 2.3,
                'GBPUSD': 47.3 + Math.cos((hours + 4) / 3) * 4.8 + Math.sin(minutes / 18) * 2.5,
                'DXY': 53.1 + Math.sin((hours + 6) / 3) * 4.0 + Math.cos(minutes / 20) * 1.6
            };
            
            let bulletValue = baseValues[symbol] || 50;
            
            if (hours >= 13 && hours <= 21) {
                bulletValue += 2.2;
            } else if (hours >= 22 || hours <= 6) {
                bulletValue -= 1.5;
            }
            
            bulletValue += (Math.random() * 1.0) - 0.5;
            
            return Math.min(100, Math.max(0, Math.round(bulletValue * 10) / 10));
        }

        // Live price function
        function getLivePrice(pair) {
            if (pair.symbol === 'XAUUSD') {
                return (5145.23 + (Math.random() * 4 - 2)).toFixed(2);
            } else if (pair.symbol === 'USOIL') {
                return (92.09 + (Math.random() * 0.3 - 0.15)).toFixed(2);
            } else {
                const variation = pair.basePrice * 0.0002;
                return (pair.basePrice + (Math.random() * variation * 2 - variation)).toFixed(
                    pair.symbol === 'DXY' ? 3 : 4
                );
            }
        }

        // Calculate Fibonacci Pivot Points
        function calculateFibonacciPivots(pair) {
            const { hours } = getTimeInTimezone();
            const timezoneOffset = (hours - 12) * 0.0001;
            
            const high = pair.prevDayHigh * (1 + timezoneOffset);
            const low = pair.prevDayLow * (1 - timezoneOffset);
            const close = pair.prevDayClose;
            const range = high - low;
            
            const pivot = (high + low + close) / 3;
            
            return {
                pivot: pivot,
                r1: pivot + range * 0.382,
                r2: pivot + range * 0.618,
                s1: pivot - range * 0.382
            };
        }

        function getPriceChange(currentPrice, basePrice) {
            let change = ((currentPrice - basePrice) / basePrice) * 100;
            return change.toFixed(2);
        }

        function getSignal(bulletValue) {
            if (bulletValue < 30) return { type: 'strong-buy', text: 'Strong Buy' };
            if (bulletValue >= 30 && bulletValue < 40) return { type: 'normal-buy', text: 'Normal Buy' };
            if (bulletValue >= 40 && bulletValue < 60) return { type: 'neutral', text: 'Neutral' };
            if (bulletValue >= 60 && bulletValue < 70) return { type: 'normal-sell', text: 'Normal Sell' };
            if (bulletValue >= 70) return { type: 'strong-sell', text: 'Strong Sell' };
            return { type: 'neutral', text: 'Neutral' };
        }

        function getSignalText(signalType, lang) {
            const translations = {
                en: {
                    'strong-buy': 'STRONG BUY',
                    'normal-buy': 'BUY',
                    'normal-sell': 'SELL',
                    'strong-sell': 'STRONG SELL',
                    'neutral': 'NEUTRAL'
                },
                hi: {
                    'strong-buy': 'मजबूत खरीद',
                    'normal-buy': 'खरीद',
                    'normal-sell': 'बिक्री',
                    'strong-sell': 'मजबूत बिक्री',
                    'neutral': 'तटस्थ'
                }
            };
            return translations[lang]?.[signalType] || signalType;
        }

        function formatTimeWithTimezone(date) {
            switch(currentTimeZone) {
                case 'UTC':
                    return date.toUTCString().split(' ')[4];
                case 'NY':
                    return date.toLocaleTimeString('en-US', { timeZone: 'America/New_York' });
                case 'London':
                    return date.toLocaleTimeString('en-GB', { timeZone: 'Europe/London' });
                case 'Tokyo':
                    return date.toLocaleTimeString('ja-JP', { timeZone: 'Asia/Tokyo' });
                case 'Sydney':
                    return date.toLocaleTimeString('en-AU', { timeZone: 'Australia/Sydney' });
                default:
                    return date.toLocaleTimeString();
            }
        }

        // Zoom functions
        function zoomIn() {
            if (zoomLevel < 150) {
                zoomLevel += 10;
                document.getElementById('main-container').style.transform = `scale(${zoomLevel/100})`;
                document.getElementById('main-container').style.transformOrigin = 'top center';
                document.getElementById('zoom-level').textContent = zoomLevel + '%';
            }
        }

        function zoomOut() {
            if (zoomLevel > 50) {
                zoomLevel -= 10;
                document.getElementById('main-container').style.transform = `scale(${zoomLevel/100})`;
                document.getElementById('main-container').style.transformOrigin = 'top center';
                document.getElementById('zoom-level').textContent = zoomLevel + '%';
            }
        }

        function updateLiveTicker() {
            const ticker = document.getElementById('live-ticker');
            ticker.innerHTML = '';
            
            pairs.forEach(pair => {
                const price = getLivePrice(pair);
                const change = getPriceChange(parseFloat(price), pair.basePrice);
                const changeClass = change >= 0 ? 'positive' : 'negative';
                const sign = change >= 0 ? '+' : '';
                
                ticker.innerHTML += `
                    <div class="live-price-item">
                        ${pair.symbol}: <span>$${price}</span>
                        <small class="${changeClass}">(${sign}${change}%)</small>
                    </div>
                `;
            });
        }

        function renderDashboard() {
            const dashboard = document.getElementById('dashboard');
            dashboard.innerHTML = '';

            pairs.forEach((pair, index) => {
                const currentPrice = getLivePrice(pair);
                const priceNum = parseFloat(currentPrice);
                const change = getPriceChange(priceNum, pair.basePrice);
                const changeClass = change >= 0 ? 'positive' : 'negative';
                const sign = change >= 0 ? '+' : '';
                
                const bulletValue = getBulletPointValue(pair.symbol);
                const signal = getSignal(bulletValue);
                const signalText = getSignalText(signal.type, currentLang);
                
                const fibPivots = calculateFibonacciPivots(pair);

                const card = document.createElement('div');
                card.className = 'card';
                card.innerHTML = `
                    <div class="card-header">
                        <span class="pair-name">${pair.symbol}</span>
                        <div style="display: flex; gap: 10px; align-items: center;">
                            <span class="live-badge">LIVE</span>
                            <button class="edit-instrument" onclick="openEditModal(${index})">✎</button>
                        </div>
                    </div>
                    
                    <div class="price-display">
                        $${typeof priceNum === 'number' ? priceNum.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 4}) : priceNum}
                        <div class="price-change ${changeClass}">
                            ${sign}${change}%
                        </div>
                    </div>
                    
                    <div class="bullet-display">
                        📈 BULLET: ${bulletValue}
                    </div>
                    
                    <div class="fibonacci-container">
                        <div class="fibonacci-item">
                            <div class="fibonacci-label">S1</div>
                            <div class="fibonacci-value fibonacci-s1">$${fibPivots.s1.toFixed(pair.symbol.includes('USD') && !pair.symbol.includes('XAU') && !pair.symbol.includes('OIL') ? 4 : 2)}</div>
                        </div>
                        <div class="fibonacci-item">
                            <div class="fibonacci-label">PIVOT</div>
                            <div class="fibonacci-value fibonacci-pivot">$${fibPivots.pivot.toFixed(pair.symbol.includes('USD') && !pair.symbol.includes('XAU') && !pair.symbol.includes('OIL') ? 4 : 2)}</div>
                        </div>
                        <div class="fibonacci-item">
                            <div class="fibonacci-label">R1</div>
                            <div class="fibonacci-value fibonacci-r1">$${fibPivots.r1.toFixed(pair.symbol.includes('USD') && !pair.symbol.includes('XAU') && !pair.symbol.includes('OIL') ? 4 : 2)}</div>
                        </div>
                        <div class="fibonacci-item">
                            <div class="fibonacci-label">R2</div>
                            <div class="fibonacci-value fibonacci-r1">$${fibPivots.r2.toFixed(pair.symbol.includes('USD') && !pair.symbol.includes('XAU') && !pair.symbol.includes('OIL') ? 4 : 2)}</div>
                        </div>
                    </div>
                    
                    <div class="signal-box ${signal.type}">
                        ${signalText}
                    </div>
                    <div class="price-details">
                        <span>📊 Time: ${currentTimeFrame}</span>
                        <span>💰 High: $${(priceNum * 1.002).toFixed(pair.symbol.includes('USD') && !pair.symbol.includes('XAU') && !pair.symbol.includes('OIL') ? 4 : 2)}</span>
                        <span>💰 Low: $${(priceNum * 0.998).toFixed(pair.symbol.includes('USD') && !pair.symbol.includes('XAU') && !pair.symbol.includes('OIL') ? 4 : 2)}</span>
                    </div>
                    <div class="update-time">
                        🕐 Updated: ${formatTimeWithTimezone(new Date())}
                    </div>
                `;
                dashboard.appendChild(card);
            });

            document.getElementById('xau-price').textContent = parseFloat(getLivePrice(pairs[0])).toFixed(2);
            document.getElementById('usoil-price').textContent = getLivePrice(pairs[1]);
            document.getElementById('last-updated').textContent = formatTimeWithTimezone(new Date());
            document.getElementById('refresh-status').textContent = 'Every Tick';
        }

        function openEditModal(index) {
            currentEditIndex = index;
            const pair = pairs[index];
            document.getElementById('edit-symbol').value = pair.symbol;
            document.getElementById('edit-name').value = pair.name;
            document.getElementById('edit-price').value = pair.basePrice;
            document.getElementById('edit-rsi').value = pair.manualRSI !== null ? pair.manualRSI : '';
            document.getElementById('edit-modal').classList.add('active');
        }

        function closeEditModal() {
            document.getElementById('edit-modal').classList.remove('active');
        }

        function saveInstrumentEdit() {
            const pair = pairs[currentEditIndex];
            pair.name = document.getElementById('edit-name').value;
            pair.basePrice = parseFloat(document.getElementById('edit-price').value);
            
            const bulletValue = document.getElementById('edit-rsi').value;
            pair.manualRSI = bulletValue ? parseFloat(bulletValue) : null;
            
            closeEditModal();
            renderPrevDayTable();
            refreshData();
        }

        function setTimeFrame(tf) {
            currentTimeFrame = tf;
            document.querySelectorAll('.timeframe-btn').forEach(btn => {
                btn.classList.remove('active');
                if (btn.textContent === tf) {
                    btn.classList.add('active');
                }
            });
            document.getElementById('current-timeframe').innerHTML = `⏰ Time: ${tf}`;
            refreshData();
        }

        function updateCandlePeriod() {
            let newPeriod = parseInt(document.getElementById('candle-period').value);
            if (newPeriod >= 2 && newPeriod <= 50) {
                currentCandlePeriod = newPeriod;
                document.getElementById('current-candle').innerHTML = `🕯️ BULLET: ${newPeriod}`;
                refreshData();
            }
        }

        function updateRefreshRate() {
            refreshInterval = 1;
            document.getElementById('refresh-rate').value = 1;
            document.getElementById('refresh-desc').innerHTML = 'Current: Auto-refresh every tick';
            document.getElementById('current-refresh').innerHTML = '🔄 Refresh: 1s (Tick)';
            document.getElementById('refresh-status').textContent = 'Every Tick';
            
            if (timer) clearInterval(timer);
            timer = setInterval(() => {
                refreshData();
            }, 1000);
            
            alert('Auto-refresh set to EVERY TICK (1 second)');
        }

        function updateTimeZone() {
            currentTimeZone = document.getElementById('timezone-select').value;
            document.getElementById('current-timezone').innerHTML = `🌐 Time: ${currentTimeZone === 'local' ? 'Local' : currentTimeZone}`;
            renderPrevDayTable();
            refreshData();
        }

        function changeLanguage(lang) {
            currentLang = lang;
            document.querySelectorAll('.lang-btn').forEach(btn => {
                btn.classList.remove('active');
                if (btn.textContent.toLowerCase().includes(lang === 'en' ? 'english' : lang)) {
                    btn.classList.add('active');
                }
            });
            refreshData();
        }

        function refreshData() {
            updateLiveTicker();
            renderDashboard();
        }

        // Initialize everything
        populatePivotDropdown();
        document.getElementById('pivot-instrument-select').addEventListener('change', loadInstrumentToPivotEditor);
        document.getElementById('pivot-prev-low').addEventListener('input', calculatePivotFromInputs);
        document.getElementById('pivot-prev-high').addEventListener('input', calculatePivotFromInputs);
        document.getElementById('pivot-prev-close').addEventListener('input', calculatePivotFromInputs);
        
        // Load first instrument by default
        setTimeout(() => {
            loadInstrumentToPivotEditor();
        }, 100);

        renderPrevDayTable();
        renderDashboard();
        updateLiveTicker();

        timer = setInterval(() => {
            refreshData();
        }, 1000);

        setInterval(() => {
            updateLiveTicker();
        }, 1000);
    </script>
